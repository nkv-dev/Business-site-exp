---
import Layout from '@/layouts/Layout.astro';
import { Mail, Phone, MapPin, Send } from 'lucide-react';
---

<Layout title="Contact Us | Acme Studio" description="Get in touch with us to start your next big digital project.">
  <div class="pt-32 pb-24 relative overflow-hidden min-h-screen">
    <!-- background glows -->
    <div class="absolute top-1/4 right-0 w-[40rem] h-[40rem] bg-primary/15 rounded-full blur-[120px] pointer-events-none" />
    <div class="absolute bottom-0 left-0 w-[40rem] h-[40rem] bg-primary/15 rounded-full blur-[120px] pointer-events-none" />

    <div class="container mx-auto px-4 md:px-8 relative z-10">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 lg:gap-24">
        
        <div>
          <h1 class="text-5xl md:text-7xl font-heading font-extrabold tracking-tight mb-6">
            Let's build <br/> <span class="text-gradient">something great</span>
          </h1>
          <p class="text-xl text-muted-foreground leading-relaxed mb-12">
            Whether you have a fully formed idea or just starting to explore digital opportunities, our team is ready to help you navigate the landscape.
          </p>

          <div class="space-y-8">
            <div class="flex items-start gap-5">
              <div class="w-14 h-14 rounded-2xl glass border border-primary/20 flex items-center justify-center text-primary shrink-0 shadow-lg">
                <Mail size={26} />
              </div>
              <div class="pt-1">
                <h4 class="text-lg font-heading font-semibold text-foreground mb-1">Email Us</h4>
                <p class="text-muted-foreground hover:text-primary transition-colors cursor-pointer">hello@acmestudio.design</p>
                <p class="text-muted-foreground hover:text-primary transition-colors cursor-pointer">careers@acmestudio.design</p>
              </div>
            </div>
            
            <div class="flex items-start gap-5">
              <div class="w-14 h-14 rounded-2xl glass border border-primary/20 flex items-center justify-center text-primary shrink-0 shadow-lg">
                <MapPin size={26} />
              </div>
              <div class="pt-1">
                <h4 class="text-lg font-heading font-semibold text-foreground mb-1">Visit Studio</h4>
                <p class="text-muted-foreground leading-relaxed">100 Innovation Way<br/>San Francisco, CA 94105</p>
              </div>
            </div>
          </div>
        </div>

        <!-- Form side -->
        <div class="glass-card border border-white/10 rounded-[3rem] p-8 md:p-12 relative overflow-hidden shadow-2xl">
            <div class="absolute -top-24 -right-24 w-64 h-64 bg-primary/20 rounded-full blur-[70px] pointer-events-none"></div>

            <h3 class="text-2xl font-heading font-bold mb-8">Send us a message</h3>
            <form class="space-y-6 relative z-10">
              <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
                <div class="space-y-2.5">
                  <label class="text-sm font-medium text-foreground ml-1">First Name</label>
                  <input type="text" class="w-full bg-background/50 border border-border/80 hover:border-primary/50 focus:border-primary rounded-2xl px-5 py-4 focus:outline-none focus:ring-1 focus:ring-primary transition-all pb-4" placeholder="John" />
                </div>
                <div class="space-y-2.5">
                  <label class="text-sm font-medium text-foreground ml-1">Last Name</label>
                  <input type="text" class="w-full bg-background/50 border border-border/80 hover:border-primary/50 focus:border-primary rounded-2xl px-5 py-4 focus:outline-none focus:ring-1 focus:ring-primary transition-all pb-4" placeholder="Doe" />
                </div>
              </div>
              
              <div class="space-y-2.5">
                <label class="text-sm font-medium text-foreground ml-1">Email</label>
                <input type="email" class="w-full bg-background/50 border border-border/80 hover:border-primary/50 focus:border-primary rounded-2xl px-5 py-4 focus:outline-none focus:ring-1 focus:ring-primary transition-all pb-4" placeholder="john@example.com" />
              </div>

              <div class="space-y-2.5">
                <label class="text-sm font-medium text-foreground ml-1">Project Details</label>
                <textarea rows="4" class="w-full bg-background/50 border border-border/80 hover:border-primary/50 focus:border-primary rounded-2xl px-5 py-4 focus:outline-none focus:ring-1 focus:ring-primary transition-all resize-none pb-4" placeholder="Tell us about your project..."></textarea>
              </div>

              <button type="button" class="w-full mt-4 rounded-2xl bg-primary text-primary-foreground hover:bg-primary/90 shadow-[0_0_20px_rgba(108,92,231,0.3)] hover:shadow-[0_0_35px_rgba(108,92,231,0.6)] transition-all h-16 flex justify-center items-center text-lg font-medium group">
                Send Inquiry
                <Send class="ml-2 w-5 h-5 group-hover:-translate-y-1 group-hover:translate-x-1 transition-transform" />
              </button>
            </form>
        </div>
      </div>
    </div>
  </div>
</Layout>
