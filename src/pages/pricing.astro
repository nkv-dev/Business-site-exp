---
import Layout from "@/layouts/Layout.astro";
import CtaSection from "@/components/home/CtaSection.astro";
import { Check } from "lucide-react";

const plans = [
  {
    name: "Starter",
    description:
      "Perfect for new businesses needing a powerful online presence.",
    price: "₹ 3500",
    features: [
      "Custom Landing Page Design",
      "Responsive Layout Built",
      "Basic SEO Setup",
      "Contact Form Integration",
      "1 Revision Round",
    ],
    popular: false,
  },
  {
    name: "Pro",
    description:
      "Ideal for growing brands that want an immersive digital experience.",
    price: "₹ 5000",
    features: [
      "Multi-Page Website (Up to 5 Pages)",
      "Premium Framer Motion Animations",
      "Advanced SEO Optimization",
      "CMS Integration for Blogs/Content",
      "Google Analytics Dashboard",
      "3 Revision Rounds",
    ],
    popular: true,
  },
  {
    name: "Enterprise",
    description:
      "Comprehensive digital solutions tailored for high-scale impact.",
    price: "Custom",
    features: [
      "Unlimited Web Pages",
      "Custom Web Applications",
      "Complex E-Commerce Functionality",
      "A/B Testing Infrastructure",
      "Dedicated Project Manager",
      "Ongoing Maintenance & Support",
    ],
    popular: false,
  },
];
---

<Layout
  title="Pricing | Acme Studio"
  description="Transparent and scalable pricing for premium web development services."
>
  <div class="pt-32 pb-24 relative overflow-hidden">
    <!-- background glows -->
    <div
      class="absolute top-1/4 right-1/4 w-[30rem] h-[30rem] bg-primary/10 rounded-full blur-[100px] pointer-events-none"
    >
    </div>
    <div
      class="absolute bottom-1/4 left-1/4 w-[40rem] h-[40rem] bg-indigo-500/10 rounded-full blur-[120px] pointer-events-none"
    >
    </div>

    <div class="container mx-auto px-4 md:px-8 relative z-10">
      <div class="max-w-3xl mx-auto text-center mb-16">
        <h1
          class="text-5xl md:text-7xl font-heading font-extrabold tracking-tight mb-6"
        >
          Premium value, <br />
          <span class="text-gradient">transparent pricing</span>
        </h1>
        <p class="text-xl text-muted-foreground leading-relaxed">
          Invest in a digital experience that converts. We offer scalable
          packages to suit your project's distinct ambitions.
        </p>
      </div>

      <div
        class="grid grid-cols-1 md:grid-cols-3 gap-8 xl:gap-12 max-w-6xl mx-auto"
      >
        {
          plans.map((plan) => (
            <div
              class={`relative rounded-[2.5rem] p-8 md:p-10 glass-card border transition-all duration-300 flex flex-col ${plan.popular ? "border-primary/50 shadow-[0_0_40px_rgba(168,85,247,0.15)] md:-translate-y-4 bg-background/80" : "border-white/5 hover:border-white/20 mt-0 md:mt-4 bg-background/40 hover:bg-background/60"}`}
            >
              {plan.popular && (
                <div class="absolute -top-4 left-1/2 -translate-x-1/2 bg-primary text-primary-foreground text-sm font-bold tracking-wider uppercase px-6 py-1.5 rounded-full shadow-[0_0_20px_rgba(168,85,247,0.5)] whitespace-nowrap z-10">
                  Most Popular
                </div>
              )}

              <div class="mb-8 relative z-10">
                <h3 class="text-3xl font-heading font-bold text-foreground mb-3">
                  {plan.name}
                </h3>
                <p class="text-muted-foreground min-h-[3rem] leading-relaxed">
                  {plan.description}
                </p>
              </div>

              <div class="mb-10 flex items-baseline gap-2">
                <span class="text-5xl lg:text-6xl font-heading font-extrabold text-white tracking-tight">
                  {plan.price}
                </span>
                {plan.price !== "Custom" && (
                  <span class="text-muted-foreground font-medium">
                    /project
                  </span>
                )}
              </div>

              <ul class="space-y-5 mb-10 flex-1">
                {plan.features.map((feature) => (
                  <li class="flex items-start gap-4">
                    <div class="shrink-0 mt-1 w-6 h-6 rounded-full bg-primary/20 flex items-center justify-center text-primary shadow-sm border border-primary/20">
                      <Check size={14} strokeWidth={3} />
                    </div>
                    <span class="text-foreground/90 leading-snug">
                      {feature}
                    </span>
                  </li>
                ))}
              </ul>

              <button
                class={`w-full rounded-2xl py-4 text-lg font-bold transition-all ${plan.popular ? "bg-primary text-primary-foreground hover:bg-primary/90 shadow-[0_4px_20px_rgba(168,85,247,0.3)] hover:shadow-[0_4px_30px_rgba(168,85,247,0.5)]" : "bg-white/5 text-foreground hover:bg-white/10 border border-white/10 hover:border-white/20"}`}
              >
                Choose {plan.name}
              </button>
            </div>
          ))
        }
      </div>
    </div>
  </div>
  <CtaSection />
</Layout>
