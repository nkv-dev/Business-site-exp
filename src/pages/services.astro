---
import Layout from '@/layouts/Layout.astro';
import CtaSection from '@/components/home/CtaSection.astro';
import { LayoutTemplate, CalendarPlus, BookOpen } from 'lucide-react';
---

<Layout title="Our Services | Acme Studio" description="Explore our web development, landing page design, event websites, and digital catalog services.">
  <div class="pt-32 pb-16 relative">
    <div class="container mx-auto px-4 md:px-8 relative z-10">
      <div class="max-w-3xl mb-24">
        <h1 class="text-5xl md:text-7xl font-heading font-extrabold tracking-tight mb-6">
          Digital solutions <br /> tailored for <span class="text-gradient">growth</span>
        </h1>
        <p class="text-xl text-muted-foreground leading-relaxed">
          We combine stunning aesthetics with rock-solid engineering to deliver digital experiences that not only look beautiful but perform exceptionally well.
        </p>
      </div>
      
      <div class="flex flex-col gap-24 lg:gap-32">
        <!-- Service 1 -->
        <div class="grid grid-cols-1 md:grid-cols-2 gap-12 lg:gap-20 items-center">
          <div class="order-2 md:order-1">
            <div class="w-16 h-16 rounded-3xl glass flex items-center justify-center text-primary mb-8 shadow-lg">
              <LayoutTemplate size={32} />
            </div>
            <h2 class="text-3xl lg:text-4xl font-heading font-bold mb-4">High-Converting Landing Pages</h2>
            <p class="text-lg text-muted-foreground mb-6 leading-relaxed">
              Your landing page is often the first touchpoint with potential customers. We design and build lightning-fast, highly optimized pages focused entirely on driving conversions and communicating your unique value proposition.
            </p>
            <ul class="space-y-4 hidden sm:block">
              <li class="flex items-center gap-3 text-muted-foreground"><div class="w-2 h-2 rounded-full bg-primary shadow-[0_0_10px_rgba(108,92,231,0.8)]" /> A/B Testing Infrastructure Ready</li>
              <li class="flex items-center gap-3 text-muted-foreground"><div class="w-2 h-2 rounded-full bg-primary shadow-[0_0_10px_rgba(108,92,231,0.8)]" /> Sub-second Load Times</li>
              <li class="flex items-center gap-3 text-muted-foreground"><div class="w-2 h-2 rounded-full bg-primary shadow-[0_0_10px_rgba(108,92,231,0.8)]" /> Conversion Rate Optimized Design</li>
            </ul>
          </div>
          <div class="order-1 md:order-2 rounded-[2.5rem] overflow-hidden aspect-video bg-muted/20 relative shadow-2xl glass-card border border-white/5">
            <img src="https://images.unsplash.com/photo-1460925895917-afdab827c52f?q=80&w=2015&auto=format&fit=crop" alt="Landing Pages" class="w-full h-full object-cover opacity-80" />
            <div class="absolute inset-0 bg-gradient-to-tr from-primary/20 to-transparent"></div>
          </div>
        </div>

        <!-- Service 2 -->
        <div class="grid grid-cols-1 md:grid-cols-2 gap-12 lg:gap-20 items-center">
          <div class="rounded-[2.5rem] overflow-hidden aspect-video bg-muted/20 relative shadow-2xl glass-card border border-white/5">
            <img src="https://images.unsplash.com/photo-1505373877841-8d25f7d46678?q=80&w=2012&auto=format&fit=crop" alt="Event Websites" class="w-full h-full object-cover opacity-80" />
            <div class="absolute inset-0 bg-gradient-to-tr from-primary/20 to-transparent"></div>
          </div>
          <div>
            <div class="w-16 h-16 rounded-3xl glass flex items-center justify-center text-primary mb-8 shadow-lg">
              <CalendarPlus size={32} />
            </div>
            <h2 class="text-3xl lg:text-4xl font-heading font-bold mb-4">Dynamic Event Websites</h2>
            <p class="text-lg text-muted-foreground mb-6 leading-relaxed">
              Create anticipation and drive ticket sales with immersive event portals. We build scalable platforms to handle high-traffic ticket drops, schedule management, and speaker showcases with seamless user experiences.
            </p>
            <ul class="space-y-4 hidden sm:block">
              <li class="flex items-center gap-3 text-muted-foreground"><div class="w-2 h-2 rounded-full bg-primary shadow-[0_0_10px_rgba(108,92,231,0.8)]" /> Secure Ticketing Integration</li>
              <li class="flex items-center gap-3 text-muted-foreground"><div class="w-2 h-2 rounded-full bg-primary shadow-[0_0_10px_rgba(108,92,231,0.8)]" /> Interactive Schedules & Maps</li>
              <li class="flex items-center gap-3 text-muted-foreground"><div class="w-2 h-2 rounded-full bg-primary shadow-[0_0_10px_rgba(108,92,231,0.8)]" /> High-Traffic Resiliency</li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </div>
  <CtaSection />
</Layout>
