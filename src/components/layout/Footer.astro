---
import { Code2, Twitter, Github, Linkedin, ArrowUpRight } from 'lucide-react';
---

<footer class="w-full bg-background border-t border-border mt-auto relative overflow-hidden">
  <!-- subtle gradient background element -->
  <div class="absolute inset-0 bg-primary/5 [mask-image:radial-gradient(ellipse_at_bottom,white,transparent_80%)] pointer-events-none"></div>
  
  <div class="container mx-auto px-4 md:px-8 py-16 relative z-10">
    <div class="grid grid-cols-1 md:grid-cols-12 gap-12 lg:gap-8">
      <!-- Brand Segment -->
      <div class="md:col-span-5 space-y-6">
        <a href="/" class="flex items-center gap-2 group w-fit">
          <div class="p-2 rounded-xl bg-primary/10 text-primary group-hover:bg-primary group-hover:text-primary-foreground transition-colors duration-300">
            <Code2 size={28} />
          </div>
          <span class="text-2xl font-heading font-bold tracking-tight text-foreground">
            Acme<span class="text-gradient">Studio</span>
          </span>
        </a>
        <p class="text-muted-foreground max-w-sm text-lg leading-relaxed">
          Crafting stunning landing pages, dynamic event sites, and converting catalogues with premium modern design.
        </p>
        <div class="flex gap-4 pt-2">
          <a href="#" class="p-2.5 rounded-full border border-border bg-background text-muted-foreground hover:text-primary hover:border-primary hover:shadow-[0_0_15px_rgba(168,85,247,0.3)] transition-all">
            <Twitter size={20} />
          </a>
          <a href="#" class="p-2.5 rounded-full border border-border bg-background text-muted-foreground hover:text-primary hover:border-primary hover:shadow-[0_0_15px_rgba(168,85,247,0.3)] transition-all">
            <Github size={20} />
          </a>
          <a href="#" class="p-2.5 rounded-full border border-border bg-background text-muted-foreground hover:text-primary hover:border-primary hover:shadow-[0_0_15px_rgba(168,85,247,0.3)] transition-all">
            <Linkedin size={20} />
          </a>
        </div>
      </div>
      
      <!-- Spacing column for desktop -->
      <div class="hidden md:block md:col-span-1 lg:col-span-2"></div>
      
      <!-- Services -->
      <div class="md:col-span-3">
        <h4 class="font-heading font-semibold text-foreground text-lg mb-6">Services</h4>
        <ul class="space-y-4">
          <li><a href="#" class="text-muted-foreground hover:text-primary flex items-center gap-1 group transition-colors">Landing Pages <ArrowUpRight size={14} class="opacity-0 group-hover:opacity-100 -translate-y-1 translate-x-1 transition-all" /></a></li>
          <li><a href="#" class="text-muted-foreground hover:text-primary flex items-center gap-1 group transition-colors">Event Websites <ArrowUpRight size={14} class="opacity-0 group-hover:opacity-100 -translate-y-1 translate-x-1 transition-all" /></a></li>
          <li><a href="#" class="text-muted-foreground hover:text-primary flex items-center gap-1 group transition-colors">Digital Catalogues <ArrowUpRight size={14} class="opacity-0 group-hover:opacity-100 -translate-y-1 translate-x-1 transition-all" /></a></li>
          <li><a href="#" class="text-muted-foreground hover:text-primary flex items-center gap-1 group transition-colors">SEO Optimization <ArrowUpRight size={14} class="opacity-0 group-hover:opacity-100 -translate-y-1 translate-x-1 transition-all" /></a></li>
        </ul>
      </div>
      
      <!-- Company -->
      <div class="md:col-span-3 lg:col-span-2">
        <h4 class="font-heading font-semibold text-foreground text-lg mb-6">Company</h4>
        <ul class="space-y-4">
          <li><a href="#" class="text-muted-foreground hover:text-primary flex items-center gap-1 group transition-colors">About Us <ArrowUpRight size={14} class="opacity-0 group-hover:opacity-100 -translate-y-1 translate-x-1 transition-all" /></a></li>
          <li><a href="#" class="text-muted-foreground hover:text-primary flex items-center gap-1 group transition-colors">Our Work <ArrowUpRight size={14} class="opacity-0 group-hover:opacity-100 -translate-y-1 translate-x-1 transition-all" /></a></li>
          <li><a href="#" class="text-muted-foreground hover:text-primary flex items-center gap-1 group transition-colors">Contact <ArrowUpRight size={14} class="opacity-0 group-hover:opacity-100 -translate-y-1 translate-x-1 transition-all" /></a></li>
        </ul>
      </div>
    </div>
    
    <div class="flex flex-col md:flex-row items-center justify-between mt-16 pt-8 border-t border-border/50 text-sm text-muted-foreground">
      <p>&copy; {new Date().getFullYear()} Acme Web Studio. All rights reserved.</p>
      <div class="flex gap-6 mt-4 md:mt-0">
        <a href="#" class="hover:text-foreground transition-colors">Privacy Policy</a>
        <a href="#" class="hover:text-foreground transition-colors">Terms of Service</a>
      </div>
    </div>
  </div>
</footer>
